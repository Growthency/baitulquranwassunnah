# Supabase — optional.
# The site runs fully without these (blog posts are bundled, forms accept input).
# Add these to persist contact/admission submissions and manage posts from the DB.
# Copy this file to ".env.local" and fill in the values from your Supabase project.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
